# Download Gateway Configuration
# Copy to .env and adjust values

DG_APP_NAME="Download Gateway"
DG_SECRET_KEY="CHANGE-ME-ON-FIRST-RUN"
DG_DEBUG=false

# Aria2 JSON-RPC
DG_ARIA2_RPC_URL="http://localhost:6800/jsonrpc"
DG_ARIA2_RPC_SECRET=""

# WireGuard / VPN
DG_WIREGUARD_CONFIG_DIR="/etc/wireguard"
DG_WIREGUARD_INTERFACE="wg0"

# Storage
DG_DOWNLOAD_DIR="/downloads"
DG_DATABASE_PATH="./data/gateway.db"

# IP Leak Detection
DG_IP_CHECK_INTERVAL=30
DG_IP_CHECK_URL="https://api.ipify.org?format=json"

# Auth
DG_JWT_EXPIRE_MINUTES=1440

# Networking
DG_LAN_SUBNET="192.168.1.0/24"

# Logging
DG_LOG_LEVEL="INFO"
